FROM python:3.14-slim

RUN pip install --no-cache-dir uv && \
    apt-get update && \
    apt-get install -y --no-install-recommends \
        build-essential \
        libffi-dev \
        libssl-dev \
        libpcap-dev \
        ffmpeg \
        git \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /usr/src/homeassistant

COPY homeassistant/ homeassistant/
COPY requirements.txt requirements_all.txt pyproject.toml README.rst LICENSE.md MANIFEST.in ./

COPY home_assistant_frontend-*.whl ./
RUN uv pip install --system -r requirements.txt && \
    uv pip install --system home_assistant_frontend-*.whl && \
    uv pip install --system -e .

EXPOSE 8123

CMD ["python3", "-m", "homeassistant", "--config", "/config"]
